-- Listen to the REAL Reward event (server fires this when you claim a reward)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Knit = ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"].knit
local RewardEvent = Knit.Services.SeasonService.RE.Reward

RewardEvent.OnClientEvent:Connect(function(...)
    local args = {...}
    print("📦 Reward event fired with arguments:")
    for i, arg in ipairs(args) do
        print(string.format("   Arg %d: %s", i, tostring(arg)))
    end
    -- If it's a table, print its contents
    for i, arg in ipairs(args) do
        if type(arg) == "table" then
            print("   Table contents:")
            for k, v in pairs(arg) do
                print(string.format("      %s = %s", k, tostring(v)))
            end
        end
    end
end)

print("✅ Listener active. Now go claim a season reward manually (like tier 5) and watch the output.")
