local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")

-- Locate SeasonService (adjust path if needed)
local seasonService = replicatedStorage:FindFirstChild("SeasonService") 
    or game:GetService("SeasonService") 
    or replicatedStorage:FindFirstChild("Services"):FindFirstChild("SeasonService")

if not seasonService then
    warn("SeasonService not found")
    return
end

local remote = seasonService:FindFirstChild("RequestRebirthReward")
if not remote then
    warn("Remote not found")
    return
end

-- Test different argument formats
local testCases = {
    { "2" },        -- Season ID as string (from config)
    { 2 },          -- Season ID as number
    { 5 },          -- Rebirth count (5)
    { 1 },          -- Tier index (like the other remote)
    { "2", 5 },     -- Season ID + rebirth count
    { "2", 1 },     -- Season ID + tier index
    { 2, 5 },       -- Number season ID + rebirth count
    {}              -- No arguments
}

for i, args in ipairs(testCases) do
    local success, result = pcall(function()
        return remote:InvokeServer(unpack(args))
    end)
    
    if success then
        print("✅ Test " .. i .. " succeeded with args:", unpack(args))
        print("   Response:", result)
        -- If it succeeded, this is the correct format!
        break
    else
        print("❌ Test " .. i .. " failed with args:", unpack(args))
        print("   Error:", result)
    end
    task.wait(0.5) -- Avoid spamming
end
