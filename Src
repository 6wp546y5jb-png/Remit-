-- ================================================================
--  Test RequestRebirthReward with "SupernovaScoreEffect" + number
-- ================================================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Knit = ReplicatedStorage:WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")

local RequestRebirthReward = Knit:WaitForChild("Services")
    :WaitForChild("SeasonService")
    :WaitForChild("RF")
    :WaitForChild("RequestRebirthReward")

local InventoryChanged = Knit:WaitForChild("Services")
    :WaitForChild("InventoryService")
    :WaitForChild("RE")
    :WaitForChild("InventoryChanged")

local found = false
local winningNumber = nil

InventoryChanged.OnClientEvent:Connect(function(itemName, count)
    if itemName == "SupernovaScoreEffect" then
        found = true
        winningNumber = count
        print(string.format("\n🎉 SUCCESS! SupernovaScoreEffect granted with number %d", winningNumber))
    end
end)

task.spawn(function()
    print("🔍 Testing RequestRebirthReward with 'SupernovaScoreEffect' + number (1–100)...")

    for i = 1, 100 do
        if found then break end

        local success, result = pcall(function()
            -- Send the item name and the number as two arguments
            RequestRebirthReward:InvokeServer("SupernovaScoreEffect", i)
        end)

        if i % 10 == 0 then
            print(string.format("   Tested %d / 100", i))
        end

        task.wait(0.3)
    end

    if not found then
        print("\n❌ Not found in 1–100.")
        print("💡 Try increasing to 10000, or try just sending the number alone.")
    else
        print(string.format("\n✅ Found it! Use number %d", winningNumber))
    end
end)
