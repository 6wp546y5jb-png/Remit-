-- ================================================================
--  SUPER FAST brute‑force for SupernovaScoreEffect
--  Tests likely remotes with numbers 1–500, 0.05s delay
-- ================================================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Knit = ReplicatedStorage:WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")

local InventoryChanged = Knit:WaitForChild("Services")
    :WaitForChild("InventoryService")
    :WaitForChild("RE")
    :WaitForChild("InventoryChanged")

local found = false
local winnerRemote, winnerNumber, winnerPattern

InventoryChanged.OnClientEvent:Connect(function(itemName, count)
    if itemName == "SupernovaScoreEffect" then
        found = true
        winnerNumber = count
        print(string.format("\n🎉 GOT IT! Remote: %s  Number: %d  Pattern: %s", winnerRemote, winnerNumber, winnerPattern))
    end
end)

-- Patterns: try both with and without item name
local patterns = {
    {name = "WithName", call = function(remote, i) return remote:InvokeServer("SupernovaScoreEffect", i) end},
    {name = "JustNumber", call = function(remote, i) return remote:InvokeServer(i) end},
}

-- Priority remotes (most likely)
local priorityRemotes = {
    Knit.Services.SeasonService.RF:FindFirstChild("RequestRebirthReward"),
    Knit.Services.SeasonService.RF:FindFirstChild("RequestRewardClaim"),
    Knit.Services.SeasonService.RF:FindFirstChild("ClaimDailyPresent"),
    -- Add more if you know them
}

-- Collect all other remotes (fallback)
local allRemotes = {}
for _, service in ipairs(Knit.Services:GetChildren()) do
    local rf = service:FindFirstChild("RF")
    if rf then
        for _, child in ipairs(rf:GetChildren()) do
            if child:IsA("RemoteFunction") then
                table.insert(allRemotes, child)
            end
        end
    end
end

-- Combine priority (non‑nil) + others, but priority first
local remotesToTest = {}
for _, r in ipairs(priorityRemotes) do
    if r then table.insert(remotesToTest, r) end
end
for _, r in ipairs(allRemotes) do
    -- avoid duplicates
    local dup = false
    for _, existing in ipairs(remotesToTest) do
        if existing == r then dup = true; break end
    end
    if not dup then table.insert(remotesToTest, r) end
end

print("🔍 Testing " .. #remotesToTest .. " remotes, numbers 1–500, 0.05s wait...")

task.spawn(function()
    for _, remote in ipairs(remotesToTest) do
        if found then break end
        local remoteName = remote.Parent.Parent.Name .. "." .. remote.Name  -- e.g., SeasonService.RequestRebirthReward
        print("\n▶ " .. remoteName)

        for _, pat in ipairs(patterns) do
            if found then break end
            winnerRemote = remoteName
            winnerPattern = pat.name

            for i = 1, 500 do
                if found then break end
                pcall(pat.call, remote, i)  -- ignore errors
                if i % 50 == 0 then
                    print(string.format("   %s: %d / 500", pat.name, i))
                end
                task.wait(0.05)  -- <-- super fast
            end

            if not found then
                print("   ❌ Pattern '" .. pat.name .. "' didn't find it in 1–500")
            end
        end
    end

    if not found then
        print("\n❌ Not found in 1–500. Try increasing to 10000 or adding more patterns.")
    end
end)
