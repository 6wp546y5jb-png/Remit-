local remote = game:GetService("ReplicatedStorage")
    :WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")
    :WaitForChild("Services")
    :WaitForChild("SeasonService")
    :WaitForChild("RF")
    :WaitForChild("RequestCurrencyRebirth")

-- Try different arguments
local testArgs = {
    {},   -- no args
    {35},  -- tier?
    {16},  -- season?
    {"16"} -- season string
}

for i, args in ipairs(testArgs) do
    local success, result = pcall(function()
        return remote:InvokeServer(unpack(args))
    end)
    print("Test", i, "→", success, result)
    if success then
        print("⚠️ Check your UI! Did your rebirth count go up?")
    end
    task.wait(1)
end
