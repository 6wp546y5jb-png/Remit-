-- Locate the InventoryChanged event (client side)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local InventoryChanged = ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"].knit.Services.InventoryService.RE.InventoryChanged

-- Loop through numbers 1 to 10000, firing the event locally with each one
task.spawn(function()
    print("🚀 Firing InventoryChanged for SupernovaScoreEffect from 1 to 10000...")

    for i = 1, 10000 do
        pcall(function()
            firesignal(InventoryChanged.OnClientEvent, "SupernovaScoreEffect", i)
        end)

        -- Optional: print progress every 100 iterations
        if i % 100 == 0 then
            print("Fired number:", i)
        end

        task.wait(0.1) -- tiny delay to avoid overwhelming the client
    end

    print("✅ Finished firing all numbers 1–10000")
end)
