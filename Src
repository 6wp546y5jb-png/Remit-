-- ============================================================
--  Brute-force RequestRebirthReward for SupernovaScoreEffect
-- ============================================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Knit = ReplicatedStorage:WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")

-- The remote you want to test
local RequestRebirthReward = Knit:WaitForChild("Services")
    :WaitForChild("SeasonService")
    :WaitForChild("RF")
    :WaitForChild("RequestRebirthReward")

-- The real InventoryChanged event (fired by the server when an item is granted)
local InventoryChanged = Knit:WaitForChild("Services")
    :WaitForChild("InventoryService")
    :WaitForChild("RE")
    :WaitForChild("InventoryChanged")

local found = false
local winningNumber = nil

-- Listen for the server saying we got the item
InventoryChanged.OnClientEvent:Connect(function(itemName, count)
    if itemName == "SupernovaScoreEffect" then
        found = true
        winningNumber = count
        print(string.format("🎉 SUCCESS! SupernovaScoreEffect granted with number: %d", winningNumber))
    end
end)

-- Brute‑force loop
task.spawn(function()
    print("🚀 Testing RequestRebirthReward with numbers 1 to 10000...")
    for i = 1, 10000 do
        if found then break end

        local success, result = pcall(function()
            RequestRebirthReward:InvokeServer(i)
        end)

        if not success then
            -- Some numbers might error (e.g., if they're invalid), we just skip
            -- Optionally print if you want: warn("Error with", i, result)
        end

        -- Show progress every 100 tries
        if i % 100 == 0 then
            print("Tested", i, "/ 10000")
        end

        task.wait(0.3)  -- Adjust to avoid rate‑limiting (0.3s is safe)
    end

    if not found then
        print("❌ SupernovaScoreEffect not found in 1–10000.")
        print("💡 Try increasing the range (e.g., to 50000) or check if the remote is correct.")
    end
end)
