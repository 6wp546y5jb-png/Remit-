-- ============================================================
--  Remote Lister – Scans and prints every RemoteEvent/RemoteFunction
--  in the game. No invoking or firing – just listing.
-- ============================================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local remotes = {}

-- Recursively scan a folder/instance and collect remotes
local function scanFolder(folder, path)
    path = path or ""
    for _, child in ipairs(folder:GetChildren()) do
        local currentPath = path .. "/" .. child.Name
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            table.insert(remotes, {
                name = child.Name,
                className = child.ClassName,
                fullPath = currentPath,
                parent = child.Parent
            })
        end
        if child:IsA("Folder") or child:IsA("Model") or child:IsA("Tool") then
            scanFolder(child, currentPath)
        end
    end
end

-- Scan common containers
print("🔍 Scanning for RemoteEvents / RemoteFunctions...")
scanFolder(ReplicatedStorage, "ReplicatedStorage")
scanFolder(LocalPlayer:WaitForChild("PlayerScripts"), "PlayerScripts")
scanFolder(game:GetService("Workspace"), "Workspace")
scanFolder(game:GetService("StarterGui"), "StarterGui")
-- Optionally, you can add more: StarterPack, ServerScriptService (but those are server-side, not accessible), etc.

-- Print results
print(string.format("\n✅ Found %d remote objects:\n", #remotes))

for i, rem in ipairs(remotes) do
    print(string.format("%d) %s  [%s]\n   Path: %s",
        i,
        rem.name,
        rem.className,
        rem.fullPath
    ))
end

print("\n📌 Done. You can now manually inspect these remotes.")
